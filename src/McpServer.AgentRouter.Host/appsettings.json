{
  "AgentRouter": {
    "BindUrl": "http://127.0.0.1:5177",
    "RequireApiKey": false,
    "DefaultProfile": "local-code",
    "AllowCloudProviders": false,
    "RunStorage": {
      "RootPath": "../../workspace/artifacts/agent-runs",
      "WriteArtifactFiles": true
    },
    "Startup": {
      "Enabled": true,
      "EnsureRunStorageRoot": true,
      "EnsureOllama": true,
      "StartOllamaIfMissing": true,
      "StopManagedOllamaOnShutdown": false,
      "OllamaExecutablePath": "ollama",
      "OllamaBaseUrl": "http://127.0.0.1:11434",
      "StartupTimeoutSeconds": 60,
      "PollIntervalMilliseconds": 500,
      "PullMissingModels": false,
      "RequiredModels": [
        "qwen2.5-coder:14b"
      ],
      "VerifyMcpToolCatalogAfterStart": true,
      "FailFastOnStartupFailure": true
    },
    "ModelProfiles": {
      "local-code": {
        "Provider": "Ollama",
        "Model": "qwen3-coder:30b",
        "BaseUrl": "http://127.0.0.1:11434",
        "ContextLength": 131072,
        "MaxOutputTokens": 32000,
        "Temperature": 0.15,
        "AllowCloudProvider": false,
        "AllowNonLoopbackBaseUrl": false,
        "TimeoutSeconds": 900
      },
      "fast-local": {
        "Provider": "Ollama",
        "Model": "qwen2.5-coder:14b",
        "BaseUrl": "http://127.0.0.1:11434",
        "ContextLength": 32768,
        "MaxOutputTokens": 12000,
        "Temperature": 0.15,
        "AllowCloudProvider": false,
        "AllowNonLoopbackBaseUrl": false,
        "TimeoutSeconds": 600
      },
      "local-agent": {
        "Provider": "Ollama",
        "Model": "qwen3-coder:30b",
        "BaseUrl": "http://127.0.0.1:11434",
        "ContextLength": 131072,
        "MaxOutputTokens": 32000,
        "Temperature": 0.1,
        "AllowCloudProvider": false,
        "AllowNonLoopbackBaseUrl": false,
        "TimeoutSeconds": 1200
      }
    },
    "McpServer": {
      "Enabled": true,
      "ExecutablePath": "../McpServer.Host/bin/Release/net10.0/McpServer.Host.exe",
      "WorkingDirectory": "../..",
      "WorkspaceRoot": "../../workspace",
      "TimeoutSeconds": 20,
      "DisableHighRiskTools": true
    },
    "AgentLoop": {
      "Enabled": true,
      "MaxSteps": 8,
      "MaxRuntimeSeconds": 300,
      "MaxOutputChars": 200000,
      "TraceEveryStep": true,
      "WriteTraceFiles": true,
      "TraceRootPath": "../../workspace/artifacts/agent-loops",
      "RequireExplicitAllowlist": true,
      "AllowedCapabilities": [
        "mcp.tools.call",
        "shell.exec",
        "ssh.exec"
      ]
    },
    "ToolExecution": {
      "Enabled": true,
      "RequireExplicitAllowlist": true,
      "TimeoutSeconds": 20,
      "MaxOutputChars": 200000,
      "WriteTraceFiles": true,
      "TraceRootPath": "../../workspace/artifacts/mcp-tool-calls",
      "AllowedTools": [
        "activity.schemas.list",
        "fs.get_metadata",
        "fs.list_directory"
      ]
    },
    "ShellExecution": {
      "Enabled": true,
      "RequireExplicitAllowlist": true,
      "TimeoutSeconds": 60,
      "MaxOutputChars": 200000,
      "WriteTraceFiles": true,
      "TraceRootPath": "../../workspace/artifacts/shell-exec",
      "WorkingDirectoryRoot": "../../workspace",
      "AllowWorkingDirectoryOutsideRoot": false,
      "AllowShellInterpreterInlineCommands": false,
      "AllowedCommands": [
        "dotnet",
        "git",
        "dir",
        "bash"
      ],
      "DeniedCommands": [
        "rm",
        "del",
        "erase",
        "rmdir",
        "shutdown",
        "reboot",
        "mkfs",
        "format",
        "diskpart",
        "sudo",
        "su"
      ]
    },
    "SshExecution": {
      "Enabled": true,
      "RequireExplicitProfileAllowlist": true,
      "TimeoutSeconds": 60,
      "MaxOutputChars": 200000,
      "WriteTraceFiles": true,
      "TraceRootPath": "../../workspace/artifacts/ssh-exec",
      "RepoProfilesFilePath": "../../config/mcpserver/ssh-profiles.local.json",
      "UserProfilesFilePath": "%LOCALAPPDATA%/McpServer/ssh-profiles.json",
      "VaultPath": "../../config/mcpserver/ssh-vault.local.json",
      "VaultKeyPath": "%LOCALAPPDATA%/McpServer/ssh-vault.key",
      "LoadRepoProfilesFile": true,
      "LoadUserProfilesFile": true,
      "AllowInlineProfiles": false,
      "AllowUnknownHostKeys": false,
      "AllowShellInterpreterInlineCommands": false,
      "AllowedCommands": [
        "pwd",
        "whoami",
        "hostname",
        "uname",
        "uptime"
      ],
      "DeniedCommands": [
        "rm",
        "del",
        "erase",
        "rmdir",
        "shutdown",
        "reboot",
        "mkfs",
        "format",
        "diskpart",
        "sudo",
        "su"
      ]
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/agent-router-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }
}
